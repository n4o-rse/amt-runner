@prefix amt:  <http://academic-meta-tool.xyz/vocab#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://github.com/leiza-scit/CAA2026-amt/> .

# =============================================================================
# AMT data file: Potter Attribution — typological dating chain
# =============================================================================
#
# A small archaeological scenario: pottery sherds carry features (figure
# types) that can be attributed to individual potters. Potters in turn
# have a known active period, which lets us derive a probable dating for
# the find context in which a sherd was excavated.
#
# The example exercises two binary chains over the four concepts
# Feature → Potter → Sherd → FindContext, and one three-step chain that
# composes them into a single feature-to-context attribution.
#
# Logic operators are chosen for what they actually mean here:
#
#   * Product       — independent attribution observations multiply:
#                     a 0.83 belief that Potter B made Sherd Z and a 0.6
#                     belief that Sherd Z dates to FindContext I yield
#                     ~0.50 for Potter B → FindContext I.
#   * Product       — Feature → Potter → Sherd is the same kind of chain.
#   * EinsteinProduct — for the full 3-step Feature → Context chain.
#                     Einstein is a stricter t-norm than Product
#                     (slightly lower across (0,1)^n), making the
#                     long-chain inference distinguishable in the
#                     output from the binary Product chains above.
#
# The companion file `PotterAttributionExample.md` contains the full
# attribution diagram and the expected inferences.

# ── Concepts ────────────────────────────────────────────────────────────────
ex:Feature rdf:type        amt:Concept ;
           rdfs:label      "Feature / Figure Type" ;
           amt:placeholder "Feature / Figure Type" .

ex:Potter rdf:type        amt:Concept ;
          rdfs:label      "Potter" ;
          amt:placeholder "Potter" .

ex:Sherd rdf:type        amt:Concept ;
         rdfs:label      "Sherd" ;
         amt:placeholder "Pot Sherd" .

ex:FindContext rdf:type        amt:Concept ;
               rdfs:label      "Find Context" ;
               amt:placeholder "Find Context" .

# ── Roles ───────────────────────────────────────────────────────────────────
# Asserted roles
ex:FeatureAttributionDegree rdf:type    amt:Role ;
                            rdfs:label  "feature attribution" ;
                            rdfs:domain ex:Feature ;
                            rdfs:range  ex:Potter .

ex:PotterAttributionDegree  rdf:type    amt:Role ;
                            rdfs:label  "potter attribution" ;
                            rdfs:domain ex:Potter ;
                            rdfs:range  ex:Sherd .

ex:WeightedDatingDegree     rdf:type    amt:Role ;
                            rdfs:label  "weighted dating" ;
                            rdfs:domain ex:Sherd ;
                            rdfs:range  ex:FindContext .

# Derived roles (consequents of role chains)
ex:FigureTypeRepertoireChoice rdf:type    amt:Role ;
                              rdfs:label  "repertoire choice" ;
                              rdfs:domain ex:Feature ;
                              rdfs:range  ex:Sherd .

ex:DatingWeight rdf:type    amt:Role ;
                rdfs:label  "dating weight" ;
                rdfs:domain ex:Potter ;
                rdfs:range  ex:FindContext .

ex:FeatureDatingWeight rdf:type    amt:Role ;
                       rdfs:label  "feature dating weight" ;
                       rdfs:domain ex:Feature ;
                       rdfs:range  ex:FindContext .

# =============================================================================
# AXIOMS
# =============================================================================

# ── Repertoire choice (Product, n=2) ────────────────────────────────────────
# Feature → Potter → Sherd composes the feature-attribution and
# potter-attribution into a direct claim that the feature is part of
# this sherd's repertoire. Product because the two attributions are
# independent observations: their confidences multiply.
ex:RCA_repertoireChoice rdf:type        amt:RoleChainAxiom ;
                        amt:antecedents ( ex:FeatureAttributionDegree
                                          ex:PotterAttributionDegree ) ;
                        amt:consequent  ex:FigureTypeRepertoireChoice ;
                        amt:logic       amt:ProductLogic .

# ── Potter-to-context dating (Product, n=2) ─────────────────────────────────
# Potter → Sherd → FindContext composes the potter-attribution and the
# sherd's weighted dating into a probable dating window for the potter
# at this find context. Product again — the two facts come from
# independent sources (typology vs. stratigraphy).
ex:RCA_potterDating rdf:type        amt:RoleChainAxiom ;
                    amt:antecedents ( ex:PotterAttributionDegree
                                      ex:WeightedDatingDegree ) ;
                    amt:consequent  ex:DatingWeight ;
                    amt:logic       amt:ProductLogic .

# ── Feature-to-context dating (Einstein product, n=3) ───────────────────────
# The full chain Feature → Potter → Sherd → FindContext, length 3.
# Choosing a logic operator here is a modelling decision, not a
# mechanical one. ProductLogic would multiply through (e.g. 0.5 * 0.6
# * 0.51 ≈ 0.153), which is the canonical "independent evidence
# multiplies" reading. EinsteinProduct is a stricter t-norm — it
# returns slightly lower values than Product everywhere on (0,1)^n —
# and is useful when the modeller wants to explicitly penalise long
# chains relative to short ones, or to keep the operator distinct from
# the binary Product chains above. See the companion .md file for a
# side-by-side table.
ex:RCA_featureDating rdf:type        amt:RoleChainAxiom ;
                     amt:antecedents ( ex:FeatureAttributionDegree
                                       ex:PotterAttributionDegree
                                       ex:WeightedDatingDegree ) ;
                     amt:consequent  ex:FeatureDatingWeight ;
                     amt:logic       amt:EinsteinProduct .

# =============================================================================
# DATA: Individuals
# =============================================================================

# ── Features (figure types) ─────────────────────────────────────────────────
ex:Feature_Red   amt:instanceOf ex:Feature ; rdfs:label "Feature Red"   .
ex:Feature_Blue  amt:instanceOf ex:Feature ; rdfs:label "Feature Blue"  .
ex:Feature_Green amt:instanceOf ex:Feature ; rdfs:label "Feature Green" .

# ── Potters ────────────────────────────────────────────────────────────────
ex:Potter_A amt:instanceOf ex:Potter ; rdfs:label "Potter A" .
ex:Potter_B amt:instanceOf ex:Potter ; rdfs:label "Potter B" .

# ── Sherds ─────────────────────────────────────────────────────────────────
ex:Sherd_X amt:instanceOf ex:Sherd ; rdfs:label "Sherd X" .
ex:Sherd_Z amt:instanceOf ex:Sherd ; rdfs:label "Sherd Z" .

# ── Find contexts ──────────────────────────────────────────────────────────
ex:FindContext_I amt:instanceOf ex:FindContext ; rdfs:label "Find Context I" .

# =============================================================================
# DATA: Asserted edges (reified statements)
# =============================================================================

# ── Branch A: Feature_Red → Potter_A → Sherd_X → FindContext_I ──────────────
# Lower-confidence attribution chain — useful to see how the three
# logics dampen long chains differently in the inferences.
_:a01 rdf:subject ex:Feature_Red ; rdf:predicate ex:FeatureAttributionDegree ; rdf:object ex:Potter_A      ; amt:weight "0.50"^^xsd:decimal .
_:a02 rdf:subject ex:Potter_A    ; rdf:predicate ex:PotterAttributionDegree  ; rdf:object ex:Sherd_X       ; amt:weight "0.60"^^xsd:decimal .
_:a03 rdf:subject ex:Sherd_X     ; rdf:predicate ex:WeightedDatingDegree     ; rdf:object ex:FindContext_I ; amt:weight "0.51"^^xsd:decimal .

# ── Branch B: Feature_Blue / Feature_Green → Potter_B → Sherd_Z → FindContext_I
# Higher-confidence branch — Potter_B is well-attested. Two features
# are attributed to Potter_B, with Feature_Green considerably weaker
# (0.33) than Feature_Blue (1.00).
_:b01 rdf:subject ex:Feature_Blue  ; rdf:predicate ex:FeatureAttributionDegree ; rdf:object ex:Potter_B      ; amt:weight "1.00"^^xsd:decimal .
_:b02 rdf:subject ex:Feature_Green ; rdf:predicate ex:FeatureAttributionDegree ; rdf:object ex:Potter_B      ; amt:weight "0.33"^^xsd:decimal .
_:b03 rdf:subject ex:Potter_B      ; rdf:predicate ex:PotterAttributionDegree  ; rdf:object ex:Sherd_Z       ; amt:weight "0.83"^^xsd:decimal .
_:b04 rdf:subject ex:Sherd_Z       ; rdf:predicate ex:WeightedDatingDegree     ; rdf:object ex:FindContext_I ; amt:weight "0.60"^^xsd:decimal .

# =============================================================================
# Expected inferences (sanity check — produced by `amt-runner`)
# =============================================================================
#
# Product (RCA_repertoireChoice — Feature → Sherd):
#   Feature_Red   -> Sherd_X    weight 0.50 * 0.60 = 0.300
#   Feature_Blue  -> Sherd_Z    weight 1.00 * 0.83 = 0.830
#   Feature_Green -> Sherd_Z    weight 0.33 * 0.83 = 0.274
#
# Product (RCA_potterDating — Potter → FindContext):
#   Potter_A -> FindContext_I   weight 0.60 * 0.51 = 0.306
#   Potter_B -> FindContext_I   weight 0.83 * 0.60 = 0.498
#
# EinsteinProduct (RCA_featureDating — Feature → FindContext, n=3):
#   Feature_Red   -> FindContext_I   weight ≈ 0.093   (ProductLogic gives 0.153)
#   Feature_Blue  -> FindContext_I   weight ≈ 0.466   (ProductLogic gives 0.498)
#   Feature_Green -> FindContext_I   weight ≈ 0.113   (ProductLogic gives 0.164)
#
# Einstein product is ≤ Product across most of [0,1]^n. On these inputs
# the gap is small at the high-confidence end (Feature_Blue) and larger
# in the mid-range. It is *not* a "gentler" operator in the absolute
# sense — but it spreads results more evenly and avoids Product's harsh
# collapse near zero on long heterogeneous chains. See
# `PotterAttributionExample.md` for a side-by-side comparison.
#
# Consistency check should pass — no integrity axioms are defined, so
# the data has nothing it could violate.
